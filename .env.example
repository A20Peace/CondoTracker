# ─── Supabase ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service-role key: server-only, NEVER expose to the client.
SUPABASE_SERVICE_ROLE_KEY=

# ─── Anthropic (parsing documenti giustificativi) ────────────────────────────
# Senza chiave, la registrazione spesa usa l'inserimento manuale (no parsing AI).
ANTHROPIC_API_KEY=

# ─── Google OAuth (login opzionale) ──────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Resend (notifiche email ai condòmini) ───────────────────────────────────
RESEND_API_KEY=
# Mittente verificato, es. "CondoTracker <noreply@tuodominio.it>"
RESEND_FROM="CondoTracker <onboarding@resend.dev>"

# ─── Cron (protezione job promemoria) ────────────────────────────────────────
# Stringa casuale; Vercel Cron la invia come Authorization bearer token.
# Genera con:  openssl rand -hex 32
CRON_SECRET=

# ─── App ─────────────────────────────────────────────────────────────────────
# URL pubblico base, usato per redirect OAuth e deep-link nelle email.
NEXT_PUBLIC_APP_URL=http://localhost:3000
